# ── Database ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=teamdocs_kh

# ── JWT ───────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ── File Upload ───────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ── Frontend URL (for CORS) ───────────────
CLIENT_URL=http://localhost:3000
